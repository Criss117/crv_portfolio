---
import CodeIcon from '../icons/CodeIcon.astro';
import ProjectCard from './ProjectCard.astro';
import {PROJECTS} from '../lib/data.astro';
---
<h2 class="text-2xl font-semibold mb-6 flex gap-x-4 items-center">
  <CodeIcon class="size-4 md:size-6"/>
  Proyectos
</h2>
<div class="grid lg:grid-cols-2 gap-10 w-full">
{
  PROJECTS.map((project) => (
    <ProjectCard project={project}/>
  ))
}
</div>