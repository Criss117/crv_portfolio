
---
import ExperienceItem from './ExperienceItem.astro';
import BriefCaseIcon from '../icons/BriefCaseIcon.astro';

type ExperienceType = {
  date: string;
  title: string;
  description: string;
  link?: string; 
};

const EXPERIENCES: ExperienceType[] = [
  {
    date: 'Enero 2024',
    title: 'Absolutamente nada',
    description: "No logré nada",
    link: '#'
  },
  {
    date: 'Enero 2023',
    title: 'Desarrollador Web',
    description: "Soy desarrollador web",
    link: undefined
  }
]
---

<h2 class="text-2xl font-semibold mb-6 flex gap-x-4 items-center">
  <BriefCaseIcon class="size-4 md:size-6"/>
  Experiencia Laboral
</h2>
<ol class="relative border-s border-gray-200 dark:border-gray-700 ml-4">
  {
    EXPERIENCES.map((experience) => (
      <li class="mb-10 ms-4">
        <ExperienceItem {...experience} />
      </li>
    ))
  }
</ol>

