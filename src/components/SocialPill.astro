---
interface Props {
  href: string
}
const { href } = Astro.props;
---

<a 
  class="
    rounded-full border border-white/10 flex 
    justify-center items-center gap-x-2 
    px-2 py-1 md:px-4 md:py-2 
    bg-white/5 hover:scale-[1.05] hover:bg-white/10 transition" 
  target="_blank"
  rel="noopener noreferrer"
  href={href}>
  <slot name="icon"/>
  <slot/>
</a>